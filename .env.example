# Copia este archivo a .env y rellena los valores reales. NO comitees .env.

# ── Servidor ──
PORT=3000
NODE_ENV=development

# ── Frontend / OAuth ──
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── APIs externas ──
THE_SPORTS_DB_API_KEY=tu-thesportsdb-key
SPORTSDB_API_KEY=tu-thesportsdb-key
TICKETMASTER_API_KEY=tu-ticketmaster-key
ANTHROPIC_API_KEY=tu-anthropic-key

# ── Cifrado de tokens de Google en la DB (AES-256-GCM) ──
# Clave de 32 bytes en hexadecimal (64 caracteres). Genérala con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: si esta clave se pierde o cambia, los tokens ya cifrados en la DB
# dejan de poder descifrarse y los usuarios afectados tendrán que reconectar Google.
TOKEN_ENCRYPTION_KEY=
